{
  "name": "astrologo-frontend",
  "version": "2.17.25",
  "description": "Astrólogo — gerador de mapas astrais e análises esotéricas via integração Gemini AI. React 19 + Vite 8 sobre Cloudflare Pages com D1 backing store.",
  "license": "AGPL-3.0-or-later",
  "author": "Leonardo Cardozo Vargas (lcv-leo)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lcv-leo/astrologo-app.git"
  },
  "homepage": "https://github.com/lcv-leo/astrologo-app#readme",
  "bugs": {
    "url": "https://github.com/lcv-leo/astrologo-app/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "biome": "biome check .",
    "biome:write": "biome check --write .",
    "test": "vitest run",
    "preview": "vite preview",
    "format": "biome format --write src"
  },
  "dependencies": {
    "@google/genai": "^2.2.0",
    "@tailwindcss/vite": "^4.3.0",
    "dompurify": "^3.4.5",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sanitize-html": "^2.17.4",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "picomatch": "4.0.4",
    "undici": "6.24.0",
    "vite": "$vite"
  }
}
